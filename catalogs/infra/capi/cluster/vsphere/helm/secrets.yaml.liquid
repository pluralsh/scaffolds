cluster:
  vsphere:
    identity:
      password: {{ configuration.password }}

controlPlane:
  sshAuthorizedKeys:
{% if configuration.sshPublicKey -%}
  - {{ configuration.sshPublicKey }}
{% endif -%}

workers:
  defaults:
    sshAuthorizedKeys:
{% if configuration.sshPublicKey -%}
  - {{ configuration.sshPublicKey }}
{% endif -%}
