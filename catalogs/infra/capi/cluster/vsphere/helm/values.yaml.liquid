cluster:
  name: {{ configuration.clusterName }}
  kubernetesVersion: {{ configuration.version }}
  vsphere:
    server: {{ configuration.server }}
    thumbprint: {{ configuration.thumbprint }}
    datacenter: {{ configuration.datacenter }}
    datastore: {{ configuration.datastore }}
    network: {{ configuration.network }}
    template: {{ configuration.template }}
    {% if configuration.resourcePool %}resourcePool: {{ configuration.resourcePool }}{% endif %}
    controlPlaneEndpoint:
      host: {{ configuration.controlPlaneEndpoint }}
      port: {{ configuration.controlPlaneEndpointPort | default: 6443 }}
    kubeVip:
      enabled: true
      address: {{ configuration.kubeVipAddress }}
    identity:
      username: {{ configuration.username }}

addons:
  cni:
    podCidr: {{ configuration.podCidr | default: "192.168.0.0/16" }}

controlPlane:
  replicas: {{ configuration.controlPlaneReplicas | default: 1 }}

{% assign workers = configuration.nodePools | from_json %}
workers:
  defaults:
    spec:
      network:
        devices:
          - dhcp4: true
            dhcp6: false
            networkName: {{ configuration.network }}
  groups:
    {% if workers and workers.size != 0 -%}
    {%- for worker in workers %}
    {{ worker.name }}:
      replicas: {{ worker.replicas | default: 1 }}
      spec:
        numCPUs: {{ worker.numCPUs | default: 2 }}
        memoryMiB: {{ worker.memoryMiB | default: 8192 }}
        diskGiB: {{ worker.diskGiB | default: 25 }}
    {% endfor -%}
    {% else %}
    md-0:
      replicas: {{ configuration.workerReplicas | default: 1 }}
      spec:
        numCPUs: {{ configuration.workerNumCPUs | default: 2 }}
        memoryMiB: {{ configuration.workerMemoryMiB | default: 8192 }}
        diskGiB: {{ configuration.workerDiskGiB | default: 25 }}
    {% endif -%}
