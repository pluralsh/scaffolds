controlPlane:
{% if context.sshPublicKey %}
  sshAuthorizedKeys:
    - {{ context.sshPublicKey | quote }}
{% else %}
  sshAuthorizedKeys: []
{% endif %}

workers:
  defaults:
{% if context.sshPublicKey %}
    sshAuthorizedKeys:
      - {{ context.sshPublicKey | quote }}
{% else %}
    sshAuthorizedKeys: []
{% endif %}
