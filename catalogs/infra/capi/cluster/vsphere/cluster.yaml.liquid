cluster:
  name: {{ context.clusterName }}
  kubernetesVersion: {{ context.version }}
  vsphere:
    template: {{ context.template }}
    {% if context.resourcePool %}resourcePool: {{ context.resourcePool }}{% endif %}
    controlPlaneEndpoint:
      host: {{ context.controlPlaneEndpoint }}
      port: {{ context.controlPlaneEndpointPort | default: 6443 }}
    kubeVip:
      enabled: true
      address: {{ context.kubeVipAddress }}

addons:
  cni:
    podCidr: {{ context.podCidr | default: "192.168.0.0/16" }}

controlPlane:
  replicas: {{ context.controlPlaneReplicas | default: 1 }}

{% assign workers = context.nodePools | from_json %}
workers:
  groups:
    {% if workers and workers.size != 0 -%}
    {%- for worker in workers %}
    {{ worker.name }}:
      replicas: {{ worker.replicas | default: 1 }}
      spec:
        numCPUs: {{ worker.numCPUs | default: 2 }}
        memoryMiB: {{ worker.memoryMiB | default: 8192 }}
        diskGiB: {{ worker.diskGiB | default: 25 }}
    {% endfor -%}
    {% else %}
    md-0:
      replicas: {{ context.workerReplicas | default: 1 }}
      spec:
        numCPUs: {{ context.workerNumCPUs | default: 2 }}
        memoryMiB: {{ context.workerMemoryMiB | default: 8192 }}
        diskGiB: {{ context.workerDiskGiB | default: 25 }}
    {% endif -%}
