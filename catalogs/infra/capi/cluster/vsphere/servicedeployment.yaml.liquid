apiVersion: deployments.plural.sh/v1alpha1
kind: ServiceDeployment
metadata:
  name: capi-cluster-{{ context.clusterName }}
  namespace: infra
spec:
{% if context.ai %}
  agentId: {{ context.ai.session.agent_id }}
{% endif %}
  name: {{ context.clusterName }}
  namespace: default
  git:
    folder: helm/capi/clusters/{{ context.clusterName }}
    ref: main
  repositoryRef:
    kind: GitRepository
    name: infra
    namespace: infra
  helm:
    chart: vsphere-workload-cluster
    git:
      folder: charts/capi/clusters/vsphere
      ref: main
    release: {{ context.clusterName }}
    valuesFiles:
    - ../../vsphere-env/{{ context.mgmtCluster }}/env.yaml
    - ../../vsphere-env/{{ context.mgmtCluster }}/secrets.yaml
    - cluster.yaml
    - secrets.yaml
  cluster: {{ context.mgmtCluster }}
