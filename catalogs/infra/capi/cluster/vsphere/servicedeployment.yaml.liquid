apiVersion: deployments.plural.sh/v1alpha1
kind: ServiceDeployment
metadata:
  name: capi-cluster-{{ context.clusterName }}
  namespace: infra
spec:
{% if context.ai %}
  agentId: {{ context.ai.session.agent_id }}
{% endif %}
  name: {{ context.clusterName }}
  namespace: default
  git:
    folder: helm/capi/clusters/{{ context.clusterName }}
    ref: main
  repositoryRef:
    kind: GitRepository
    name: infra
    namespace: infra
  sources:
  - path: vsphere-env
    repositoryRef:
      kind: GitRepository
      name: infra
      namespace: infra
    git:
      folder: helm/capi/vsphere-env/{{ context.mgmtCluster }}
      ref: main
  helm:
    chart: vsphere-workload-cluster
    git:
      folder: capi/clusters/vsphere
      ref: main
    repositoryRef:
      kind: GitRepository
      name: scaffolds
      namespace: infra
    release: {{ context.clusterName }}
    valuesFiles:
    - vsphere-env/env.yaml
    - vsphere-env/secrets.yaml
    - cluster.yaml
    - secrets.yaml
  cluster: {{ context.mgmtCluster }}
