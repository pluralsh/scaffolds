apiVersion: deployments.plural.sh/v1alpha1
kind: ServiceDeployment
metadata:
  name: capi-cluster-{{ context.clusterName }}
  namespace: infra
spec:
{% if context.ai %}
  agentId: {{ context.ai.session.agent_id }}
{% endif %}
  name: {{ context.clusterName }}
  namespace: default
  git:
    folder: helm/capi/clusters/{{ context.clusterName }}
    ref: main
  repositoryRef:
    kind: GitRepository
    name: infra
    namespace: infra
  helm:
    chart: vsphere-workload-cluster
    git:
      folder: charts/capi/clusters/vsphere
      ref: main
    release: {{ context.clusterName }}
    valuesFiles:
    - values.yaml.liquid
    - secrets.yaml.liquid
  configuration:
    clusterName: {{ context.clusterName }}
    version: {{ context.version }}
    server: {{ context.server }}
    thumbprint: {{ context.thumbprint }}
    datacenter: {{ context.datacenter }}
    datastore: {{ context.datastore }}
    network: {{ context.network }}
    template: {{ context.template }}
    {% if context.resourcePool %}resourcePool: {{ context.resourcePool }}{% endif %}
    controlPlaneEndpoint: {{ context.controlPlaneEndpoint }}
    controlPlaneEndpointPort: "{{ context.controlPlaneEndpointPort }}"
    kubeVipAddress: {{ context.kubeVipAddress }}
    username: {{ context.username }}
    password: {{ context.password }}
    sshPublicKey: {{ context.sshPublicKey }}
    workerReplicas: "{{ context.workerReplicas }}"
    podCidr: {{ context.podCidr }}
    nodePools: '{{ context.nodePools }}'
  cluster: {{ context.mgmtCluster }}
