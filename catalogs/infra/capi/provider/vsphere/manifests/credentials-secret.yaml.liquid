apiVersion: v1
kind: Secret
metadata:
  name: capv-credentials
  namespace: capv-system
type: Opaque
stringData:
  VSPHERE_USERNAME: {{ context.username | quote }}
  VSPHERE_PASSWORD: {{ context.password | quote }}
  VSPHERE_SERVER: {{ context.server | quote }}
  VSPHERE_TLS_THUMBPRINT: {{ context.thumbprint | quote }}
