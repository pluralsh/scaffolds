apiVersion: deployments.plural.sh/v1alpha1
kind: ServiceDeployment
metadata:
  name: capv-provider-{{ context.cluster }}
  namespace: infra
spec:
{% if context.ai %}
  agentId: {{ context.ai.session.agent_id }}
{% endif %}
  name: capv
  namespace: capv-system
  git:
    folder: helm/capi/providers/vsphere/{{ context.cluster }}
    ref: main
  repositoryRef:
    kind: GitRepository
    name: infra
    namespace: infra
  helm:
    chart: cluster-api-provider-vsphere
    git:
      folder: charts/capi/providers/vsphere
      ref: main
    valuesFiles:
    - values.yaml.liquid
    - secrets.yaml.liquid
  configuration:
    server: {{ context.server }}
    username: {{ context.username }}
    thumbprint: {{ context.thumbprint }}
    password: {{ context.password }}
    capvVersion: {{ context.capvVersion }}
  cluster: {{ context.cluster }}
