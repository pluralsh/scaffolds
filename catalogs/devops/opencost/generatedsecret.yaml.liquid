{% if context.auth == 'credentials' %}
apiVersion: deployments.plural.sh/v1alpha1
kind: GeneratedSecret
metadata:
  name: opencost-prometheus-auth
  namespace: infra
spec:
  template:
    username: {{ context.username }}
    password: '{{ context.password }}'
  destinations:
  - name: opencost-prometheus-auth
    namespace: opencost
{% endif %}
